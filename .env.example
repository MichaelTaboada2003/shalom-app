# Required application values
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret

# Required only to dispatch birthday reminder emails
RESEND_API_KEY=re_xxxxxxxxx
REMINDER_FROM_EMAIL=Shalom App <recordatorios@tu-dominio.com>
CRON_SECRET=replace-with-a-long-random-secret
# Optional: password used by npm run db:seed (defaults to Shalom2026!)
SEED_ADMIN_PASSWORD=Shalom2026!
